    <script type="text/javascript">
        jQuery(document).ready(function($) {
            slide();

            setInterval(function() {
                slide();
            }, 30000);
        });

        function slide() {
            $('.panoroma').css({
                'background-position': -3000 + $(window).width() + 'px 0'
            });

            setTimeout(function() {
                $('.panoroma').css({
                    'background-position': '0 0'
                });
            }, 15000);
        }
    </script>

