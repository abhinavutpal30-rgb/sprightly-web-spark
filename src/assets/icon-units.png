    <section id="greenf">
        <div class="container">
            <div class="col-md-12 wrap1">
                <div class="col-md-12">
                    <div class="section-title">
                        Green Features for Eco-Friendly Living
                    </div>
                    <div class="section-subtitle relative">
                        <img src="images/div.png" class="img-responsive divider" style="
					display: block;
					margin: 0 auto;
                    width: 50px;
					">
                    </div>
                    <p style="margin-top:-15px;margin-bottom:30px;text-align:center ">We offer smart water solutions
                        like dual piping, dual flush systems,
                        efficient fixtures, recycled
                        water use, rainwater harvesting, and groundwater recharge for sustainability.</p>
                </div>

            </div>
        </div>
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-12 flex-mob">
                    <div class="col-md-6 col-xs-12 d-flex align-items-center justify-content-center left-img">
                        <img src="images/newimages/environment.jpg" class="sizing" alt="Feature Image">
                        <p class="abso">Stock Image</p>
                    </div>
                    <div class="col-md-6 ">
                        <div class="col-md-4 col-xs-12">
                            <div class="key-feature">

                                <div class="key-feature-img">
                                    <img src="images/newimages/feature3.png" alt="">
                                </div>
                                <div class="">
                                    <p class="headfea">Water Conservation </p>
                                    <p class="me1">Advanced rainwater harvesting, dual plumbing systems, and
                                        water-efficient fixtures ensure optimal water usage while promoting long-term
                                        sustainability.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 col-xs-12 ">
                            <div class="key-feature">

                                <div class="key-feature-img">
                                    <img src="images/newimages/feature2.png" alt="">
                                </div>
                                <div class="">
                                    <p class="headfea">Energy Efficiency </p>
                                    <p class="me1"> Solar-powered common areas, LED lighting, and EV charging stations
                                        are seamlessly integrated to reduce energy consumption and support a greener
                                        lifestyle.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 col-xs-12">
                            <div class="key-feature">

                                <div class="key-feature-img">
                                    <img src="images/newimages/feature1.png" alt="">
                                </div>
                                <div class="">
                                    <p class="headfea">Waste Management</p>
                                    <p class="me1"> A zero-waste approach, organic waste converters, and efficient waste
                                        segregation minimize landfill impact, fostering a cleaner and healthier
                                        community.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>


            </div>
        </div>
    </section>




